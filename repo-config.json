    "fix": {
      "label": "수정",
      "conventionalPrefixes": ["fix"],
      "linePatterns": ["^(fix|수정|버그|bug|patch|hotfix)\\b"]
    },
    "improve": {
      "label": "개선",
      "conventionalPrefixes": ["improve", "perf"],
