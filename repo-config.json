    "^(typo|오타)\\s*(fix|수정)?\\s*$",
    "^(minor|small)\\s*(fix|change|update|tweak)\\b",
    "^(clean\\s*up|cleanup|정리)\\s*$",
    "^(style|lint|format|prettier|eslint)\\b",
    "^(rebase|squash|amend|cherry-pick)\\b",
    "^\\.(gitignore|editorconfig|eslintrc|prettierrc)\\b",
    "^(rename|move)\\s+(file|dir|folder)\\b",
    "^(apply|add|use)\\s+(shared|common|공통)\\s+workflow",
    "^bump[-_]?automation[-_]?ref\\b",
    "^(add|apply)\\s+.*(claude|gemini).*workflow",
